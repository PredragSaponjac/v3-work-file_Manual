# ORCA V3 — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Anthropic (Claude — Stage 1 catalyst hunt, Stage 2 flow reader, Stage 3 confirmation)
ANTHROPIC_API_KEY=sk-ant-...

# Unusual Whales API (options flow, dark pool, OI data)
# 20,000 req/day · 120 req/min
UW_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Google Sheets (trade tracker — public view, bot writes)
# base64 -i service_account.json | tr -d '\n'
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CREDS=

# Optional — override AI models per stage
# STAGE1_MODEL=claude-sonnet-4-20250514
# FLOW_MODEL=claude-sonnet-4-20250514
# CONFIRM_MODEL=claude-sonnet-4-20250514

# Polygon.io (optional — for historical OHLCV)
POLYGON_API_KEY=

# ── v20 Source Layer ──

# OpenAI (GPT — multi-model consensus, final judge)
OPENAI_API_KEY=sk-proj-...

# Google Gemini (CIO integrator, synthesis)
GEMINI_API_KEY=AIzaSy...

# X / Twitter (publishing + whitelist ingestion)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# EIA — Energy Information Administration
# Register: https://www.eia.gov/opendata/register.php
# Used for petroleum inventories, nat gas storage, energy releases
EIA_API_KEY=

# AISstream — AIS vessel tracking (marine/shipping intelligence)
# Register: https://aisstream.io/
# Used for tanker congestion, shipping disruptions, port traffic
AISSTREAM_API_KEY=
